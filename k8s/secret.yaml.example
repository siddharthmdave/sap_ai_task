# k8s/secret.yaml.example
# =========================================================
# Kubernetes Secret Template - DO NOT commit real values
# =========================================================
# Create the actual secret with:
# kubectl create secret generic etl-service-secrets \
#   --from-literal=SECRET_KEY="$(openssl rand -hex 32)" \
#   --from-literal=OPENAI_API_KEY="sk-..." \
#   --from-literal=CSRF_SECRET_KEY="$(openssl rand -hex 32)"
# =========================================================
apiVersion: v1
kind: Secret
metadata:
  name: etl-service-secrets
  namespace: default
type: Opaque
stringData:
  SECRET_KEY: "REPLACE_WITH_STRONG_SECRET"
  CSRF_SECRET_KEY: "REPLACE_WITH_CSRF_SECRET"
  OPENAI_API_KEY: "REPLACE_WITH_OPENAI_KEY"
  ANTHROPIC_API_KEY: ""
  AZURE_OPENAI_API_KEY: ""
  ALLOWED_ORIGINS: "https://your-frontend.example.com"
  ALLOWED_HOSTS: "api.example.com"